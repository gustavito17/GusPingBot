# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─────────────────────────────────────────
#  REQUIRED
# ─────────────────────────────────────────

# Comma-separated URLs to keep alive
PINGBOT_TARGETS=https://api-backend.onrender.com,https://frontend-app.onrender.com,https://worker-service.onrender.com

# ─────────────────────────────────────────
#  OPTIONAL — Scheduling & HTTP behaviour
# ─────────────────────────────────────────

# Cron: seconds minutes hours day month weekday
# Default: every 10 minutes → "0 */10 * * * *"
# Every 5 min  → "0 */5 * * * *"
# Every 1 min  → "0 * * * * *"
PINGBOT_CRON=0 */10 * * * *

# Timeout per HTTP request in seconds
PINGBOT_TIMEOUT_SECONDS=10

# Retries on transient errors (network timeouts, 5xx)
PINGBOT_MAX_RETRIES=2

# Port the bot itself listens on
PORT=8080

# ─────────────────────────────────────────
#  OPTIONAL — Alertas (a implementar)
# ─────────────────────────────────────────

# Discord: Settings del servidor → Integraciones → Webhooks → Copiar URL
PINGBOT_ALERT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Slack: api.slack.com → Your Apps → Incoming Webhooks → Activate
PINGBOT_ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Cuántos fallos consecutivos antes de enviar alerta (default: 1)
PINGBOT_ALERT_FAILURE_THRESHOLD=1
